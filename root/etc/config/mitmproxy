config mitmproxy 'main'
	option enabled '0'
	option image 'mitmproxy/mitmproxy'
	option container_name 'mitmproxy'
	option confdir '/etc/mitmproxy'
	option listen_host '0.0.0.0'
	option listen_port '8080'
	option web_host '0.0.0.0'
	option web_port '8081'
	option web_password ''
	option intercept_http '1'
	option intercept_https '1'
	option block_quic '1'
	option ipv6_enabled '0'
	option rules_enabled '0'
	option last_error ''
	list interface 'br-lan'
	list exclude_cidr '127.0.0.0/8'
	list exclude_cidr6 '::1/128'
	list exclude_cidr6 'fe80::/10'
